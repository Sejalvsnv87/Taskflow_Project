{
  "name": "taskflow-backend",
  "version": "1.0.0",
  "description": "TaskFlow REST API - Smart Task & Project Manager",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:memory": "tsx watch src/dev-server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "tsx src/database/init.ts",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "mysql-memory-server": "^1.14.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
